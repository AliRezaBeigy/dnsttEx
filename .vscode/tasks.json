{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Integration: Delay 5s for server",
            "type": "shell",
            "command": "powershell -NoProfile -Command \"Start-Sleep -Seconds 5\"",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "Integration: Print keys",
            "type": "shell",
            "command": "go",
            "args": [
                "test",
                "-tags=integration",
                "-run=^$",
                "./integration"
            ],
            "options": {
                "env": {
                    "DNSTT_INTEGRATION_PRINT_KEYS": "1"
                },
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "group": "none"
        }
    ]
}
